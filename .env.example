# Example environment variables for this project.
# Copy this file to ".env" (and/or ".env.production") and keep them out of git.
# Both files are already ignored by .gitignore.

# ── Public CRA variables (must start with REACT_APP_) ───────────────
# Tudo prefixado com REACT_APP_ é EMBUTIDO no bundle final e fica
# visível para qualquer usuário no navegador. Nunca coloque segredos
# reais aqui — apenas valores públicos (URLs, chaves restritas a
# domínio, etc.).
# REACT_APP_API_URL=https://api.example.com
# REACT_APP_API_KEY=public_key_only_never_a_real_secret

# ── Hardening de build de produção ──────────────────────────────────
# Não publique source maps em produção (evita expor o código-fonte
# legível no diretório /static/js/*.map do GitHub Pages).
GENERATE_SOURCEMAP=false

# Desabilita o shim de eval do webpack-dev-server em build
# (apenas afeta dev; mantém CSP mais estrita possível).
INLINE_RUNTIME_CHUNK=false
